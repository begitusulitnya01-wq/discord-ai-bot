# Salin file ini menjadi .env dan isi dengan nilai yang sesuai

# Token bot Discord kamu (wajib)
# Dapatkan di: https://discord.com/developers/applications
TOKEN=ISI_TOKEN_BOT_KAMU_DISINI

# Prefix perintah bot (default: !)
PREFIX=!

# (Opsional) Spotify API credentials untuk support Spotify
# Daftarkan di: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
